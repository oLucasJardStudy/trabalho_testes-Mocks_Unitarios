{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": ["es6"],
    "types": ["node", "jest"],
    "allowJs": true,
    "outDir": "build",
    "rootDirs": ["./src", "__tests__"],
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts", "__tests__/**/*.ts"]
}
